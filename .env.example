# PaperPilot 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# LLM API 配置（OpenAI 兼容接口）
# 支持 OpenAI、DeepSeek、Ollama 等任何兼容接口
LLM_API_KEY=your_openai_compatible_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 可选：如果习惯使用 OpenAI 默认环境变量名，也可以填写此项。
# 当 LLM_API_KEY 为空时，系统会尝试读取 OPENAI_API_KEY。
OPENAI_API_KEY=
